<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.TorneoMK" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/mk_red</item>
        <item name="colorPrimaryVariant">@color/mk_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:colorBackground">@color/mk_black</item>
        <item name="android:textColor">@color/white</item>


    </style>

    <style name="ReglaItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="drawableStartCompat">@drawable/ic_shield</item>
        <item name="android:drawablePadding">12dp</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <style name="H3TitleStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:layout_gravity">center_vertical</item>
    </style>

    <style name="BaseListItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>
</resources>